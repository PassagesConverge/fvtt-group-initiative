  "readme": "https://github.com/PassagesConverge/fvtt-group-initiative/blob/main/README.md",
  "manifest": "https://github.com/PassagesConverge/fvtt-group-initiative/releases/latest/download/module.json",
  "download": "https://github.com/PassagesConverge/fvtt-group-initiative/releases/latest/download/fvtt-group-initiative.zip"
