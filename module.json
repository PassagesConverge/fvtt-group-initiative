{
  "id": "fvtt-group-initiative",
  "title": "FVTT Group Initiative",
  "description": "A module for DnD5e that enables the creation of custom initiative groups with average-based sorting and a collapsible combat tracker display. Still in BETA.",
  "version": "1.0.1",
  "authors": [
    {
      "name": "imalane",
      "discord": "",
      "flags": {}
    }
  ],
  "compatibility": {
    "minimum": "13",
    "verified": "13"
  },
  "relationships": {
    "requires": [
      {
        "id": "lib-wrapper",
        "type": "module",
        "manifest": "https://github.com/ruipin/fvtt-lib-wrapper/releases/latest/download/module.json",
        "compatibility": {
          "verified": "1.12.7.1"
        }
      }
    ]
  },
  "esmodules": [
    "scripts/main.js",
    "scripts/class-objects.js",
    "scripts/combat-tracker.js",
    "scripts/group-header-rendering.js",
    "scripts/rolling-overrides.js",
    "scripts/settings.js",
    "scripts/shared.js",
    "scripts/carousel-integration.js"
  ],
  "styles": [
    "styles/styles.css"
  ],
